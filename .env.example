# MANIMA — deployment configuration (task 1.2, deployment spec: single env file).
#
# Copy to `.env` and edit. `.env` is git-ignored and read by `docker compose` and the
# `make` entrypoint. This example carries PLACEHOLDERS ONLY — never a real secret.
#
# Two shapes:
#   • render-only (default)  — the sovereign path. Needs only Docker. No GPU/vLLM/Qdrant.
#   • generate  (opt-in)     — adds local generation. Needs a GPU + external vLLM + Qdrant.
#
# ─────────────────────────────────────────────────────────────────────────────
# Deployment mode
# ─────────────────────────────────────────────────────────────────────────────
# 1 = render-only. The server wires ONLY the render path and imports no generate
# dependency (invariant 6). Leave this at 1 unless you are running the generate profile.
MANIMA_RENDER_ONLY=1

# ─────────────────────────────────────────────────────────────────────────────
# Server-read knobs (manima_server/config.py — ServerConfig.from_env)
# Everything not listed here takes its dataclass default; these are the env overrides
# the server actually reads.
# ─────────────────────────────────────────────────────────────────────────────
# Content-addressed artifact store and job DB. Keep on the WSL2 filesystem, never under
# /mnt/c (project.md) — cross-boundary I/O is slow for multi-megabyte video.
#MANIMA_STORE_ROOT=/home/you/.manima/store
#MANIMA_JOB_DB=/home/you/.manima/jobs.db

# Sandbox container runtime: "docker" (default) or "podman" (daemonless, rootless).
#MANIMA_CONTAINER_CLI=docker
# Set to 1 to skip --memory/--cpus/--pids-limit (rootless podman without cgroup-v2
# delegation). Leave unset to enforce the caps.
#MANIMA_NO_RESOURCE_LIMITS=0

# ─────────────────────────────────────────────────────────────────────────────
# Generate profile ONLY (ignored when MANIMA_RENDER_ONLY=1)
# ─────────────────────────────────────────────────────────────────────────────
# vLLM OpenAI-compatible endpoint serving Apertus 8B. Kept EXTERNAL — GPU-bound and
# deployment-specific, so the compose file does not start it (design D2).
#MANIMA_VLLM_URL=http://localhost:8000/v1
# Escalation gate 1 (ADR-003): server-level permission for the hosted fallback. Deny by
# default; only meaningful with the two other gates also satisfied.
#MANIMA_ALLOW_ESCALATION=0
# Read by the escalation adapter FROM THE ENVIRONMENT only when escalation runs. Never a
# config field, never committed. Placeholder — supply your own in the real .env.
#ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# ─────────────────────────────────────────────────────────────────────────────
# Deployment / compose knobs (read by docker-compose.yml and scripts, not by config.py)
# ─────────────────────────────────────────────────────────────────────────────
# The pinned Manim CE version is the single source of truth in
# manima_server/manima_server/version.py; `make` injects it into the image build. This
# override exists only for a raw `docker compose build` and should normally stay unset.
#MANIM_CE_VERSION=0.18.1
# Qdrant endpoint + collection for the generate profile's grounding corpus.
#QDRANT_URL=http://localhost:6333
#QDRANT_COLLECTION=manim-ce
